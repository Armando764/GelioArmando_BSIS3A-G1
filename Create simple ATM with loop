GelioChoice = input("Please select (1-4): ")

if GelioChoice == '1':
    print(f"Current Balance: ₱{GelioBalance}")

elif GelioChoice == '2':
  GelioDeposit = int(input("Enter amount to deposit: "))
    if GelioDeposit <= 0:
        print("Error: Invalid Amount.")
    else:
       GelioBalance = GelioBalance + GelioDeposit
        print(f"Success! ₱{GelioDeposit} added.")

elif GelioChoice == '3':
    GelioWithdraw = int(input("Enter amount to withdraw: "))
    if GelioWithdraw <= 0:
        print("Error: Invalid Amount.")
    elif GelioWithdraw < 20:
        print("Error: Minimum withdrawal amount is ₱20.")
    elif GelioWithdraw > GelioBalance:
        print("Error: Insufficient funds!")
    else:
        GelioBalance = GelioBalance - GelioWithdraw
        print(f"Success! ₱{GelioWithdraw} withdrawn.")

elif GelioChoice == '4':
    print("Thank you!")
    GelioIsActive = False

else:
    print("Invalid choice. Please try again.")
